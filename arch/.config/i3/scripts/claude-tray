#!/bin/bash

STATE_DIR="/tmp/claude-sessions"
ICON_DIR="/home/mrosiek/.config/i3/icons"
PIPE="/tmp/claude-tray-pipe"

mkdir -p "$STATE_DIR" "$ICON_DIR"

rm -f "$PIPE"
mkfifo "$PIPE"
exec 3<>"$PIPE"

magick -size 48x48 xc:none -fill '#444444' -draw 'circle 24,24 24,38' "$ICON_DIR/claude-status.png" 2>/dev/null

yad --notification \
    --listen \
    --no-middle \
    --image="$ICON_DIR/claude-status.png" \
    --text="Claude: no sessions" \
    --command="true" \
    <&3 &
YAD_PID=$!

trap "kill $YAD_PID 2>/dev/null; rm -f $PIPE; exit" EXIT INT TERM

prev_hash=""

while kill -0 $YAD_PID 2>/dev/null; do
    now=$(date +%s)
    colors=()
    tooltip_lines=()

    claude_pids=$(pgrep -x claude 2>/dev/null | wc -l)
    if [ "$claude_pids" -eq 0 ]; then
        rm -f "$STATE_DIR"/*.json
    fi

    for f in "$STATE_DIR"/*.json; do
        [ -f "$f" ] || continue
        mod=$(stat -c %Y "$f")
        age=$(( now - mod ))
        if [ "$age" -gt 180 ]; then
            rm -f "$f"
            continue
        fi

        status=$(jq -r '.status // "idle"' "$f" 2>/dev/null)
        topic=$(jq -r '.topic // empty' "$f" 2>/dev/null)
        cwd=$(jq -r '.cwd // empty' "$f" 2>/dev/null)
        label="${topic:-${cwd##*/}}"
        [ -z "$label" ] && label="unknown"
        label=$(echo "$label" | sed 's/<[^>]*>//g; s/&/\&amp;/g')

        cwd_short="${cwd/#$HOME/~}"
        if [ ${#label} -gt 30 ]; then
            label="${label:0:30}..."
        fi
        case "$status" in
            needs_attention)
                colors+=("#ff5555")
                tooltip_lines+=("<span color='#ff5555'>●</span>  <span color='#666666'>${cwd_short}</span>\\n     <b>${label}</b>  <i>needs input</i>")
                ;;
            working)
                colors+=("#50fa7b")
                tooltip_lines+=("<span color='#50fa7b'>●</span>  <span color='#666666'>${cwd_short}</span>\\n     <b>${label}</b>  <i>working</i>")
                ;;
            *)
                colors+=("#999999")
                tooltip_lines+=("<span color='#999999'>●</span>  <span color='#666666'>${cwd_short}</span>\\n     <b>${label}</b>  <i>idle</i>")
                ;;
        esac
    done

    cur_hash="${colors[*]}"
    if [ "$cur_hash" != "$prev_hash" ]; then
        prev_hash="$cur_hash"
        n=${#colors[@]}

        if [ "$n" -eq 0 ]; then
            magick -size 48x48 xc:none -fill '#444444' -draw 'circle 24,24 24,38' "$ICON_DIR/claude-status.png" 2>/dev/null
            echo "icon:$ICON_DIR/claude-status.png" >&3
            echo "tooltip:Claude: no sessions" >&3
        else
            r=6
            size=48
            case "$n" in
                1)
                    positions=("24,24")
                    ;;
                2)
                    positions=("14,24" "34,24")
                    ;;
                3)
                    positions=("24,10" "10,36" "38,36")
                    ;;
                4)
                    positions=("12,12" "36,12" "12,36" "36,36")
                    ;;
                5)
                    positions=("12,12" "36,12" "24,24" "12,36" "36,36")
                    ;;
                *)
                    positions=("8,12" "24,12" "40,12" "8,36" "24,36" "40,36")
                    r=5
                    ;;
            esac

            draw_cmds=""
            for i in "${!colors[@]}"; do
                [ "$i" -ge "${#positions[@]}" ] && break
                IFS=',' read -r cx cy <<< "${positions[$i]}"
                draw_cmds="$draw_cmds -fill '${colors[$i]}' -draw 'circle $cx,$cy $cx,$((cy + r))'"
            done

            eval magick -size ${size}x${size} xc:none $draw_cmds "$ICON_DIR/claude-status.png" 2>/dev/null
            echo "icon:$ICON_DIR/claude-status.png" >&3
            tooltip=$(printf '%s\\n' "${tooltip_lines[@]}")
            echo "tooltip:$tooltip" >&3
        fi
    fi

    sleep 2
done
